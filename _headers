# ─── Cloudflare Pages / Netlify response headers ─────────────────────────────
#
# Strategy: HTML must always revalidate (so new deploys are picked up immediately),
# CSS/JS/data get a short TTL (repeat visits are fast, updates propagate within an hour),
# and static assets that never change (fonts, images) get a long TTL.
#
# Because filenames are not content-hashed, we deliberately avoid long TTLs on
# CSS/JS to prevent users from getting stale code after a deploy.
#
# NOTE (pre-requisite): in Cloudlare it was necessary to set:
#    caching -> configuration -> Browser Cache TTL -> Respect Existing Headers

# HTML — always revalidate (covers root and subdirectory entry points;
# a single * greedily matches forward slashes in Cloudflare Pages)
/*.html
  Cache-Control: no-cache

# Page fragments and story sources — short TTL matches data files; noindex so raw
# fragments aren't indexed as standalone pages (the SPA routes are the canonical URLs)
/pages/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=60
  X-Robots-Tag: noindex
/stories/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=60
  X-Robots-Tag: noindex

# Root (SPA — served as index.html)
/
  Cache-Control: no-cache

# SPA route entry points — no-cache so they stay in sync with index.html
/buscar
  Cache-Control: no-cache
/conexiones
  Cache-Control: no-cache
/estadisticas
  Cache-Control: no-cache
/estadisticas/inmigracion
  Cache-Control: no-cache
/estadisticas/personalidades
  Cache-Control: no-cache
/estadisticas/apellidos
  Cache-Control: no-cache
/mapa
  Cache-Control: no-cache
/historias
  Cache-Control: no-cache
/historias/*
  Cache-Control: no-cache
/testimonios
  Cache-Control: no-cache
/colabora
  Cache-Control: no-cache
/recursos
  Cache-Control: no-cache
/cronologia
  Cache-Control: no-cache
/sobre-nosotros
  Cache-Control: no-cache

# CSS and JavaScript — 1 hour
/css/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=60

/js/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=60

# Data files — 1 hour (personalities.json, surnames.json, etc.); noindex so raw JSON
# isn't indexed as standalone pages
/data/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=60
  X-Robots-Tag: noindex

# Crawl metadata — 1 day
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400

# Images — 1 week
/img/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Fonts — 1 year (these never change)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
